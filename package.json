{
  "name": "expense-tracker",
  "version": "1.3.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"App.tsx\" \"index.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"App.tsx\" \"index.ts\"",
    "check": "npm run typecheck && npm run lint"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.5",
    "@react-navigation/stack": "^7.8.5",
    "date-fns": "^4.1.0",
    "expo": "~55.0.6",
    "expo-constants": "~55.0.7",
    "expo-crypto": "^55.0.9",
    "expo-document-picker": "^55.0.8",
    "expo-file-system": "^55.0.10",
    "expo-font": "~55.0.4",
    "expo-image-picker": "~55.0.14",
    "expo-local-authentication": "^55.0.8",
    "expo-notifications": "^55.0.12",
    "expo-secure-store": "^55.0.8",
    "expo-sharing": "^55.0.11",
    "expo-sqlite": "^55.0.10",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.2",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-paper": "^5.15.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.3",
    "react-native-uuid": "^2.0.3",
    "react-native-vector-icons": "^10.3.0",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.12"
