<?xml version="1.0" encoding="utf-8"?>
<!--
    Widget layout for the Expense Tracker quick-add home screen widget.
    Uses only RemoteViews-compatible views: LinearLayout, TextView, ImageView.
    Two clickable areas set via setOnClickPendingIntent in ExpenseWidget.kt.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:background="@drawable/widget_background">

    <!-- ── Header row: app icon + title + "Quick Add" badge ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="10dp">

        <!-- App launcher icon (small) for visual brand identity -->
        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="fitCenter"
            android:layout_marginEnd="8dp" />

        <!-- App name in bold white -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Expense Tracker"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <!-- "Quick Add" subtitle badge — right-aligned -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Quick Add"
            android:textColor="#99FFFFFF"
            android:textSize="11sp"
            android:fontFamily="sans-serif" />

    </LinearLayout>

    <!-- Thin divider between header and action buttons -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@drawable/widget_divider"
        android:layout_marginBottom="10dp" />

    <!-- ── Action buttons row: expense (left) and income (right) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- ── ADD EXPENSE button ── -->
        <!-- Tapping this fires the "expense-tracker://quick-add?type=expense" deep link -->
        <LinearLayout
            android:id="@+id/btn_add_expense"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/btn_widget_expense"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp">

            <!-- Red "+" icon circle indicator -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="#FF6B6B"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <!-- Button label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add Expense"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- ── PAYMENT RECEIVED button ── -->
        <!-- Tapping this fires the "expense-tracker://quick-add?type=income" deep link -->
        <LinearLayout
            android:id="@+id/btn_payment_received"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/btn_widget_income"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp">

            <!-- Green arrow-down icon indicator -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="↓"
                android:textColor="#34D399"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black" />

            <!-- Button label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Got Payment"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
