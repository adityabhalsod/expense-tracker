<?xml version="1.0" encoding="utf-8"?>
<!-- Expense button background: semi-transparent red pill shape -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <!-- Semi-transparent red tint — won't overpower the dark card background -->
    <solid android:color="#2AEF4444" />
    <!-- Rounded pill corners for modern button appearance -->
    <corners android:radius="12dp" />
</shape>
